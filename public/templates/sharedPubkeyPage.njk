{% extends "layout.njk" %}
{% block main %}

/**
 * A Solana public key: a 32-byte value with base58 encoding/decoding.
 *
 * Requires the GMP extension (ext-gmp) for base58 conversions.
 */
final class Pubkey implements \Stringable
{
    private const ALPHABET = '123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz';

    /** @param string $bytes The raw 32 bytes of the public key. */
    public function __construct(public readonly string $bytes)
    {
        if (\strlen($bytes) !== 32) {
            throw new \InvalidArgumentException('A public key must be exactly 32 bytes');
        }
    }

    public static function fromBase58(string $base58): self
    {
        return new self(self::base58Decode($base58, 32));
    }

    public function toBase58(): string
    {
        return self::base58Encode($this->bytes);
    }

    public function __toString(): string
    {
        return $this->toBase58();
    }

    public function equals(self $other): bool
    {
        return $this->bytes === $other->bytes;
    }

    public static function base58Encode(string $bytes): string
    {
        self::ensureGmp();
        $length = \strlen($bytes);
        $zeros = 0;
        while ($zeros < $length && $bytes[$zeros] === "\x00") {
            $zeros++;
        }
        $encoded = \str_repeat('1', $zeros);
        if ($zeros === $length) {
            return $encoded;
        }
        $number = \gmp_import(\substr($bytes, $zeros), 1, \GMP_MSW_FIRST | \GMP_NATIVE_ENDIAN);
        $digits = '';
        while (\gmp_cmp($number, 0) > 0) {
            $digits .= self::ALPHABET[\gmp_intval(\gmp_mod($number, 58))];
            $number = \gmp_div_q($number, 58);
        }
        return $encoded . \strrev($digits);
    }

    public static function base58Decode(string $encoded, ?int $length = null): string
    {
        self::ensureGmp();
        $zeros = 0;
        $total = \strlen($encoded);
        while ($zeros < $total && $encoded[$zeros] === '1') {
            $zeros++;
        }
        $number = \gmp_init(0);
        for ($i = 0; $i < $total; $i++) {
            $index = \strpos(self::ALPHABET, $encoded[$i]);
            if ($index === false) {
                throw new \InvalidArgumentException('Invalid base58 character: ' . $encoded[$i]);
            }
            $number = \gmp_add(\gmp_mul($number, 58), $index);
        }
        $bytes = \gmp_cmp($number, 0) === 0
            ? ''
            : \gmp_export($number, 1, \GMP_MSW_FIRST | \GMP_NATIVE_ENDIAN);
        $decoded = \str_repeat("\x00", $zeros) . $bytes;
        if ($length !== null && \strlen($decoded) !== $length) {
            throw new \InvalidArgumentException(
                'Expected ' . $length . ' decoded bytes, got ' . \strlen($decoded),
            );
        }
        return $decoded;
    }

    private static function ensureGmp(): void
    {
        if (!\extension_loaded('gmp')) {
            throw new ClientException(
                'The generated client requires the GMP extension (ext-gmp) for base58 support.',
            );
        }
    }
}
{% endblock %}
