{% extends "layout.njk" %}
{% block main %}

/**
 * Program Derived Address (PDA) helpers.
 *
 * Requires the GMP extension (ext-gmp) for the ed25519 on-curve check.
 */
final class Pda
{
    private const MARKER = 'ProgramDerivedAddress';
    private const MAX_SEEDS = 16;
    private const MAX_SEED_LENGTH = 32;

    private function __construct() {}

    /**
     * Derives the program address for the given seeds, i.e.
     * sha256(seeds || program_id || "ProgramDerivedAddress").
     * Throws a {@see PdaException} when the resulting address lies on
     * the ed25519 curve.
     *
     * @param list<string> $seeds Raw byte strings (max 16 seeds of max 32 bytes).
     */
    public static function createProgramAddress(array $seeds, Pubkey $programId): Pubkey
    {
        if (\count($seeds) > self::MAX_SEEDS) {
            throw new \InvalidArgumentException('Too many seeds (max ' . self::MAX_SEEDS . ')');
        }
        $buffer = '';
        foreach ($seeds as $seed) {
            if (\strlen($seed) > self::MAX_SEED_LENGTH) {
                throw new \InvalidArgumentException(
                    'Max seed length exceeded (max ' . self::MAX_SEED_LENGTH . ' bytes)',
                );
            }
            $buffer .= $seed;
        }
        $hash = \hash('sha256', $buffer . $programId->bytes . self::MARKER, true);
        if (self::isOnCurve($hash)) {
            throw new PdaException('Invalid seeds, address must fall off the curve');
        }
        return new Pubkey($hash);
    }

    /**
     * Finds a valid program address and its bump seed by trying bump bytes
     * from 255 down to 0 (appended as an extra seed).
     *
     * @param list<string> $seeds Raw byte strings.
     * @return array{0: Pubkey, 1: int} The derived address and bump seed.
     */
    public static function findProgramAddress(array $seeds, Pubkey $programId): array
    {
        for ($bump = 255; $bump >= 0; $bump--) {
            try {
                return [self::createProgramAddress([...$seeds, \chr($bump)], $programId), $bump];
            } catch (PdaException) {
                // Address was on the curve; try the next bump.
            }
        }
        throw new PdaException('Unable to find a viable program address bump seed');
    }

    /**
     * Returns true when the given 32 bytes are a valid compressed ed25519
     * point, following the decoding procedure of RFC 8032 §5.1.3: the point
     * is on the curve iff x² = (y² - 1) / (d·y² + 1) is a quadratic residue
     * modulo p = 2^255 - 19 (with the x = 0 / sign bit corner case).
     */
    public static function isOnCurve(string $bytes): bool
    {
        if (\strlen($bytes) !== 32) {
            return false;
        }
        self::ensureGmp();

        $p = \gmp_sub(\gmp_pow(2, 255), 19);
        // The twisted Edwards curve constant d = -121665 / 121666 mod p.
        $d = \gmp_init('37095705934669439343138083508754565189542113879843219016388785533085940283555');

        $sign = (\ord($bytes[31]) >> 7) & 1;
        $yBytes = \substr($bytes, 0, 31) . \chr(\ord($bytes[31]) & 0x7F);
        $y = \gmp_import($yBytes, 1, \GMP_LSW_FIRST | \GMP_NATIVE_ENDIAN);
        if (\gmp_cmp($y, $p) >= 0) {
            return false; // Non-canonical y coordinate.
        }

        $y2 = \gmp_mod(\gmp_mul($y, $y), $p);
        $u = \gmp_mod(\gmp_sub($y2, 1), $p);
        $v = \gmp_mod(\gmp_add(\gmp_mul($d, $y2), 1), $p);
        // v is never 0 mod p (-1/d is not a square), so Fermat inversion
        // yields the modular inverse of v.
        $x2 = \gmp_mod(\gmp_mul($u, \gmp_powm($v, \gmp_sub($p, 2), $p)), $p);

        if (\gmp_cmp($x2, 0) === 0) {
            // x = 0: decodable iff the sign bit is 0.
            return $sign === 0;
        }

        // Candidate root: x = x2^((p + 3) / 8) mod p.
        $x = \gmp_powm($x2, \gmp_div_q(\gmp_add($p, 3), 8), $p);
        if (\gmp_cmp(\gmp_mod(\gmp_sub(\gmp_mul($x, $x), $x2), $p), 0) !== 0) {
            // Multiply by sqrt(-1) = 2^((p - 1) / 4) mod p and retry.
            $x = \gmp_mod(\gmp_mul($x, \gmp_powm(2, \gmp_div_q(\gmp_sub($p, 1), 4), $p)), $p);
        }
        // On the curve iff x² ≡ x2 (mod p), i.e. x2 is a quadratic residue.
        return \gmp_cmp(\gmp_mod(\gmp_sub(\gmp_mul($x, $x), $x2), $p), 0) === 0;
    }

    private static function ensureGmp(): void
    {
        if (!\extension_loaded('gmp')) {
            throw new ClientException(
                'The generated client requires the GMP extension (ext-gmp) for PDA derivation.',
            );
        }
    }
}
{% endblock %}
