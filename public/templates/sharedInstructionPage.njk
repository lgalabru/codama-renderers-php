{% extends "layout.njk" %}
{% block main %}

/**
 * A built Solana instruction: program ID, ordered account metas and
 * serialized instruction data.
 */
final class Instruction
{
    /**
     * @param list<AccountMeta> $accounts
     * @param string $data Raw instruction data bytes.
     */
    public function __construct(
        public readonly Pubkey $programId,
        public readonly array $accounts,
        public readonly string $data,
    ) {}
}
{% endblock %}
